<Window x:Class="Fazmis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FAZMIS - Zarządzanie Pizzerią" Height="700" Width="1000" MinWidth="900" 
        MinHeight="600" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F0F0F0" Padding="10">
            <StackPanel>
                <TextBlock Text="MENU GŁÓWNE" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                <Button x:Name="BtnRefresh" Content="🔄 Odśwież Dane" Margin="0,5" Padding="10" Click="BtnRefresh_Click"/>
                <Separator Margin="0,10"/>
                <TextBlock Text="Kopia Zapasowa" FontWeight="Bold" Margin="0,10,0,5"/>
                <Button x:Name="BtnExportAll" Content="📥 Eksportuj Bazę" Click="BtnExportAll_Click" Margin="0,2"/>
                <Button x:Name="BtnImportAll" Content="📤 Importuj Bazę" Click="BtnImportAll_Click" Margin="0,2"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Column="1" x:Name="MainTabs">

            <TabItem Header="📦 Magazyn">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="DgWarehouse" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,10,0" SelectionChanged="DgWarehouse_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID_Item}" Width="40"/>
                            <DataGridTextColumn Header="Produkt" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Ilość" Binding="{Binding Quantity}" Width="60"/>
                            <DataGridTextColumn Header="Jedn." Binding="{Binding Unit}" Width="50"/>
                            <DataGridTextColumn Header="Min. Stan" Binding="{Binding MinStock}" Width="70"/>
                            <DataGridTextColumn Header="Kategoria." Binding="{Binding CategoryName}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="1" Background="#F9F9F9" Padding="10" BorderBrush="#DDD" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="ZARZĄDZAJ PRODUKTEM" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                            <TextBlock Text="Nazwa towaru:"/>
                            <TextBox x:Name="TxtProdName" Margin="0,0,0,10"/>
                            <TextBlock Text="Aktualna ilość:"/>
                            <TextBox x:Name="TxtProdQty" PreviewTextInput="NumberValidationTextBox" Margin="0,0,0,10"/>
                            <TextBlock Text="Jednostka (np. kg, szt):"/>
                            <TextBox x:Name="TxtProdUnit" Margin="0,0,0,10"/>
                            <TextBlock Text="Stan minimalny:"/>
                            <TextBox x:Name="TxtProdMin" PreviewTextInput="NumberValidationTextBox" Margin="0,0,0,10"/>
                            <TextBlock Text="Kategoria:"/>
                            <TextBox x:Name="TxtProdCat" Margin="0,0,0,15"/>

                            <Button x:Name="BtnSaveProduct" Content="💾 Dodaj Nowy" Padding="5" Background="#E1F5FE" Click="BtnSaveProduct_Click" Margin="0,2"/>
                            <Button x:Name="BtnUpdateProduct" Content="✏️ Aktualizuj Zaznaczony" Padding="5" Background="#FFF9C4" Click="BtnUpdateProduct_Click" Margin="0,2"/>
                            <Button x:Name="BtnDeleteProduct" Content="🗑 Usuń z Magazynu" Background="#FFE5E5" Padding="5" Margin="0,10,0,0" Click="BtnDeleteProduct_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="🏷 Kategorie">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="DgCategories" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,10,0" SelectionChanged="DgCategories_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID_Category}" Width="40"/>
                            <DataGridTextColumn Header="Nazwa Kategorii" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Typ" Binding="{Binding Type}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="1" Background="#F9F9F9" Padding="10" BorderBrush="#DDD" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="EDYCJA KATEGORII" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                            <TextBlock Text="Nazwa kategorii:"/>
                            <TextBox x:Name="TxtCatName" Margin="0,0,0,10"/>
                            <TextBlock Text="Typ (np. Składnik):"/>
                            <TextBox x:Name="TxtCatType" Margin="0,0,0,15"/>

                            <Button x:Name="BtnSaveCategory" Content="💾 Dodaj" Background="#F3E5F5" Margin="0,2" Click="BtnSaveCategory_Click"/>
                            <Button x:Name="BtnUpdateCategory" Content="✏️ Aktualizuj" Background="#FFF9C4" Margin="0,2" Click="BtnUpdateCategory_Click"/>
                            <Button x:Name="BtnDeleteCategory" Content="🗑 Usuń" Background="#FFE5E5" Margin="0,10" Click="BtnDeleteCategory_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="🚚 Dostawcy">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="DgSuppliers" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,10,0" SelectionChanged="DgSuppliers_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ID_Supplier}" Width="40"/>
                            <DataGridTextColumn Header="Nazwa Firmy" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="100"/>
                            <DataGridTextColumn Header="Miasto" Binding="{Binding City}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="1" Background="#F9F9F9" Padding="10" BorderBrush="#DDD" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="DANE DOSTAWCY" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                            <TextBlock Text="Nazwa firmy:"/>
                            <TextBox x:Name="TxtSupName" Margin="0,0,0,10"/>
                            <TextBlock Text="Telefon kontaktowy:"/>
                            <TextBox x:Name="TxtSupPhone" PreviewTextInput="NumberValidationTextBox" Margin="0,0,0,5"/>
                            <TextBlock Text="Miasto / Adres:"/>
                            <TextBox x:Name="TxtSupCity" Margin="0,0,0,15"/>

                            <Button x:Name="BtnSaveSupplier" Content="💾 Dodaj Dostawcę" Background="#E8F5E9" Margin="0,2" Click="BtnSaveSupplier_Click"/>
                            <Button x:Name="BtnUpdateSupplier" Content="✏️ Aktualizuj Dane" Background="#FFF9C4" Margin="0,2" Click="BtnUpdateSupplier_Click"/>
                            <Button x:Name="BtnDeleteSupplier" Content="🗑 Usuń Dostawcę" Background="#FFE5E5" Margin="0,10" Click="BtnDeleteSupplier_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="📑 Zamówienia">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="150"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Lista Zamówień (Nagłówki):" FontWeight="Bold" Margin="0,0,0,5"/>
                        <DataGrid x:Name="DgOrders" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DgOrders_SelectionChanged" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID Zamówienia" Binding="{Binding ID_Order}" Width="100"/>
                                <DataGridTextColumn Header="Data" Binding="{Binding OrderDate}" Width="*"/>
                                <DataGridTextColumn Header="ID Dostawcy" Binding="{Binding ID_Supplier}" Width="100"/>
                                <DataGridTextColumn Header="Wartość" Binding="{Binding TotalValue}" Width="80"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="2" Text="Szczegóły (Pozycje w zamówieniu):" FontWeight="Bold" Margin="0,10,0,5"/>
                        <DataGrid Grid.Row="3" x:Name="DgOrderDetails" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID Produktu" Binding="{Binding ID_Item}" Width="100"/>
                                <DataGridTextColumn Header="Ilość" Binding="{Binding Quantity}" Width="80"/>
                                <DataGridTextColumn Header="Cena jedn." Binding="{Binding UnitPrice}" Width="100"/>
                                <DataGridTextColumn Header="Suma" Binding="{Binding Suma}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <Border Grid.Column="1" Background="#F9F9F9" Padding="15" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="EDYCJA ZAMÓWIENIA" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                <TextBlock Text="ID Dostawcy:"/>
                                <TextBox x:Name="TxtOrdSupId" Margin="0,0,0,10" Height="25"/>
                                <TextBlock Text="Status (Nowe, Opłacone, Odebrane):"/>
                                <TextBox x:Name="TxtOrdStatus" Margin="0,0,0,10" Height="25"/>
                                <Button x:Name="BtnCreateOrder" Content="➕ Utwórz Nowe Zamówienie" Click="BtnCreateOrder_Click" Background="#E8F5E9" Height="35" Margin="0,0,0,5"/>
                                <Button x:Name="BtnUpdateOrder" Content="✏️ Aktualizuj Nagłówek" Click="BtnUpdateOrder_Click" Background="#FFF9C4" Height="35" Margin="0,0,0,5"/>
                                <Button x:Name="BtnDeleteOrder" Content="🗑 Usuń Całe Zamówienie" Click="BtnDeleteOrder_Click" Background="#FFE5E5" Height="35" FontWeight="Bold"/>

                                <Separator Margin="0,15"/>
                                <TextBlock Text="DODAJ/EDYTUJ POZYCJĘ" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Wybrane Zamówienie (ID):"/>
                                <TextBox x:Name="TxtDetOrderId" IsReadOnly="True" Background="#EEE" Margin="0,0,0,5"/>
                                <TextBlock Text="ID Produktu z Magazynu:"/>
                                <TextBox x:Name="TxtDetProdId" Margin="0,0,0,5"/>
                                <TextBlock Text="Ilość:"/>
                                <TextBox x:Name="TxtDetQty" Margin="0,0,0,5"/>
                                <TextBlock Text="Cena za jednostkę:"/>
                                <TextBox x:Name="TxtDetPrice" Margin="0,0,0,10"/>

                                <Button x:Name="BtnAddDetail" Content="🛒 Dodaj do Listy" Click="BtnAddDetail_Click" Background="#E8F5E9" Margin="0,2"/>
                                <Button x:Name="BtnUpdateDetail" Content="✏️ Zmień Pozycję" Click="BtnUpdateDetail_Click" Background="#FFF9C4" Margin="0,2"/>
                                <Button x:Name="BtnDeleteDetail" Content="🗑 Usuń Pozycję" Click="BtnDeleteDetail_Click" Background="#FFE5E5" Margin="0,2"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="🍕 Przepisy">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="150"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Menu Dań:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <DataGrid Grid.Row="1" x:Name="DgRecipes" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DgRecipes_SelectionChanged" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding ID_Recipe}" Width="40"/>
                                <DataGridTextColumn Header="Nazwa Dania" Binding="{Binding DishName}" Width="*"/>
                                <DataGridTextColumn Header="Cena w Menu" Binding="{Binding Price}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="2" Text="Składniki wybranego dania:" FontWeight="Bold" Margin="0,10,0,5"/>
                        <DataGrid Grid.Row="3" x:Name="DgRecipeIngredients" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DgRecipeIngredients_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID Produktu" Binding="{Binding ID_Item}" Width="100"/>
                                <DataGridTextColumn Header="Wymagana Ilość" Binding="{Binding Ilość}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <Border Grid.Column="1" Background="#F9F9F9" Padding="15" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="DANE DANIA" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Nazwa (np. Pizza Margherita):"/>
                                <TextBox x:Name="TxtRecipeName" Margin="0,0,0,5"/>
                                <TextBlock Text="Cena w menu:"/>
                                <TextBox x:Name="TxtRecipePrice" Margin="0,0,0,10"/>

                                <Button x:Name="BtnSaveRecipe" Content="➕ Dodaj Danie" Click="BtnSaveRecipe_Click" Background="#E8F5E9" Margin="0,2"/>
                                <Button x:Name="BtnUpdateRecipe" Content="✏️ Aktualizuj Danie" Click="BtnUpdateRecipe_Click" Background="#FFF9C4" Margin="0,2"/>
                                <Button x:Name="BtnDeleteRecipe" Content="🗑 Usuń Danie" Click="BtnDeleteRecipe_Click" Background="#FFE5E5" Margin="0,2"/>

                                <Separator Margin="0,15"/>
                                <TextBlock Text="SKŁADNIKI (RECEPTURA)" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="ID Produktu z Magazynu:"/>
                                <TextBox x:Name="TxtIngredId" Margin="0,0,0,5"/>
                                <TextBlock Text="Wymagana ilość:"/>
                                <TextBox x:Name="TxtIngredQty" Margin="0,0,0,10"/>

                                <Button x:Name="BtnAddIngredient" Content="🧂 Dodaj Składnik" Click="BtnAddIngredient_Click" Background="#FFF9C4" Margin="0,2"/>
                                <Button x:Name="BtnUpdateIngredient" Content="✏️ Edytuj Ilość" Click="BtnUpdateIngredient_Click" Background="#FFF9C4" Margin="0,2"/>
                                <Button x:Name="BtnDeleteIngredient" Content="❌ Usuń Składnik" Click="BtnDeleteIngredient_Click" Background="#FFE5E5" Margin="0,2"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="📉 Zużycie">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="DgUsedProducts" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,10,0" SelectionChanged="DgUsedProducts_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data" Binding="{Binding UsageDate}" Width="120"/>
                            <DataGridTextColumn Header="Ilość" Binding="{Binding QuantityUsed}" Width="80"/>
                            <DataGridTextColumn Header="Powód" Binding="{Binding Reason}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="1" Background="#F9F9F9" Padding="10" BorderBrush="#DDD" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="RAPORTUJ STRATY/ZUŻYCIE" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                            <TextBlock Text="ID Produktu:"/>
                            <TextBox x:Name="TxtUsedProdId" Margin="0,0,0,10"/>
                            <TextBlock Text="Ilość:"/>
                            <TextBox x:Name="TxtUsedQty" Margin="0,0,0,10"/>
                            <TextBlock Text="Powód (np. przeterminowanie):"/>
                            <TextBox x:Name="TxtUsedReason" Margin="0,0,0,15"/>

                            <Button x:Name="BtnAddUsage" Content="📉 Zapisz Zużycie" Background="#FFF3E0" Click="BtnAddUsage_Click" Margin="0,2"/>
                            <Button x:Name="BtnUpdateUsage" Content="✏️ Edytuj Zapis" Background="#FFF9C4" Margin="0,2" Click="BtnUpdateUsage_Click"/>
                            <Button x:Name="BtnDeleteUsage" Content="🗑 Usuń z Historii" Background="#FFE5E5" Margin="0,10" Click="BtnDeleteUsage_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>